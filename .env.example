CONDOCHARGE_ENV=development
CONDOCHARGE_API_HOST=0.0.0.0
CONDOCHARGE_API_PORT=8000

# SQLite for development (default)
CONDOCHARGE_DATABASE_URL=sqlite+pysqlite:///./condocharge_dev.sqlite3

# Required in pilot/production. Do NOT keep the default.
# Use a strong 32+ byte secret and rotate it securely.
CONDOCHARGE_JWT_SECRET_KEY=replace-with-a-strong-32-byte-secret
CONDOCHARGE_JWT_ALGORITHM=HS256
CONDOCHARGE_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30

# JSON array of exact frontend origins for browser access.
# Local example:
# CONDOCHARGE_CORS_ORIGINS=["http://localhost:5173"]
# Pilot example:
# CONDOCHARGE_CORS_ORIGINS=["https://pilot.condocharge.example"]
CONDOCHARGE_CORS_ORIGINS=["http://localhost:5173"]
CONDOCHARGE_PUBLIC_URL=
CONDOCHARGE_LAN_MODE=false

# Email / SMTP
CONDOCHARGE_EMAIL_ENABLED=false
CONDOCHARGE_EMAIL_FROM=noreply@condocharge.local
CONDOCHARGE_SMTP_HOST=
CONDOCHARGE_SMTP_PORT=587
CONDOCHARGE_SMTP_USERNAME=
CONDOCHARGE_SMTP_PASSWORD=
CONDOCHARGE_SMTP_USE_TLS=true
CONDOCHARGE_NOTIFICATIONS_ENABLED=false
CONDOCHARGE_NOTIFICATION_POLL_INTERVAL_SECONDS=30
CONDOCHARGE_NOTIFICATION_RECENCY_MINUTES=30
CONDOCHARGE_NOTIFICATION_STATION_COOLDOWN_MINUTES=15
CONDOCHARGE_NOTIFICATION_RESIDENT_COOLDOWN_MINUTES=5

# Local/dev only:
# - the seeded admin/admin account is for development convenience only
# - production must use a non-default admin password
# - pilot/production must not ship with change-me JWT secret
# - wildcard CORS is not allowed in pilot/production

# Pilot runtime example:
# CONDOCHARGE_ENV=pilot
# CONDOCHARGE_DATABASE_URL=sqlite+pysqlite:///./pilot.sqlite3
# CONDOCHARGE_JWT_SECRET_KEY=replace-with-a-strong-32-byte-secret
# CONDOCHARGE_PUBLIC_URL=https://pilot.condocharge.example

# Explicit LAN-only example:
# CONDOCHARGE_ENV=development
# CONDOCHARGE_LAN_MODE=true
# CONDOCHARGE_PUBLIC_URL=http://lan-host-or-private-ip:5173

# Optional (future): station discovery/polling via local network
CONDOCHARGE_STATION_A_HOST=station-a.local
CONDOCHARGE_STATION_B_HOST=station-b.local
